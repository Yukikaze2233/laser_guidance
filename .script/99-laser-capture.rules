# UGREEN 95348 capture card — persistent /dev/laser_capture symlink
# Uses device serial number, portable across machines and USB ports.
# Install: sudo cp .script/99-laser-capture.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger
#
# For a second UGREEN card: copy this file, change serial to the other card's.
# Find serial: udevadm info -n /dev/video0 | grep ID_SERIAL_SHORT

SUBSYSTEM=="video4linux", ENV{ID_SERIAL_SHORT}=="20250910", SYMLINK+="laser_capture"

# If both cards have the SAME serial, use USB port instead:
# SUBSYSTEM=="video4linux", KERNELS=="2-4", SYMLINK+="laser_capture"
# Find port: udevadm info -a -n /dev/video0 | grep 'looking at parent.*usb'
