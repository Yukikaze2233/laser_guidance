# Legacy udev rule — configs now use /dev/v4l/by-id/ directly (no udev needed).
# To use this instead: change device_path in configs to /dev/laser_capture.
# Install: sudo cp .script/99-laser-capture.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

# Bind laser capture by vendor:product (portable across machines and USB ports).
# Only select UVC index 0 so the symlink never lands on the index 1 metadata node.
# Check with: udevadm info -q property -n /dev/videoX | grep ID_VENDOR_ID
# MiniPC laser card (Hagibis MACROSILICON 345f:2130):
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="345f", ATTRS{idProduct}=="2130", ATTR{index}=="0", SYMLINK+="laser_capture"

# Alternative for duplicate-serial UGREEN 95348 cards: bind by physical USB port.
# Edit KERNELS after checking: udevadm info -a -n /dev/videoX | grep KERNELS==
# SUBSYSTEM=="video4linux", KERNELS=="8-1:1.0", ATTR{index}=="0", SYMLINK+="laser_capture"
