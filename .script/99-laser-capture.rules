# Legacy udev rule — configs now use /dev/v4l/by-id/ directly (no udev needed).
# To use this instead: change device_path in configs to /dev/laser_capture.
# Install: sudo cp .script/99-laser-capture.rules /etc/udev/rules.d/
#          sudo udevadm control --reload-rules && sudo udevadm trigger

SUBSYSTEM=="video4linux", ENV{ID_SERIAL_SHORT}=="20250910", SYMLINK+="laser_capture"

# If both cards have the SAME serial, use USB port instead:
# SUBSYSTEM=="video4linux", KERNELS=="2-4", SYMLINK+="laser_capture"
